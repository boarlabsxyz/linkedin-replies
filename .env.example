# Slack bot token (xoxb-…). Bot needs scopes:
#   chat:write, channels:history, channels:read, reactions:read, groups:history
# Invite the bot to #linkedin-replies before first run.
SLACK_BOT_TOKEN=

# Resolved Slack channel ID (Cxxxxxxxxxx). Get it from the channel URL or
# Slack > channel > "View channel details" > bottom of the modal.
SLACK_CHANNEL_ID=

# Your Slack user ID (Uxxxxxxxxxx). Used by the remote-poll agent to
# distinguish your edit replies from the bot's own messages.
SLACK_HUMAN_USER_ID=

# Sales Navigator lead-alerts URL to scrape.
SALES_NAV_URL=https://www.linkedin.com/sales/home?alertGroup=LEAD&listId=7451883417308237824

# Path to the Claude Code CLI binary. Override if 'claude' isn't on PATH for launchd.
CLAUDE_BIN=claude
